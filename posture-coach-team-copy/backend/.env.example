# Environment Variables
# Copy this file to .env and fill in your values

# Neon PostgreSQL Connection String
# Get this from: neon.tech → Your Project → Connect button
DATABASE_URL=postgresql://username:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# JWT Secret Key (change this to any random long string)
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# App Settings
APP_NAME=Posture Coach API
API_V1_PREFIX=/api/v1
